# =========================================================
# BALANCE MORAL
# =========================================================
class BalanceMoral:
    def __init__(self):
        self.bien = 100
        self.mal = 20
        self.regla = "El mal existe, pero nunca supera al bien"

    def normalizar(self):
        if self.bien < 1:
            self.bien = 1

        if self.mal >= self.bien:
            self.mal = self.bien - 1

        if self.mal < 0:
            self.mal = 0

    def fortalecer_bien(self, cantidad):
        self.bien += max(0, int(cantidad))
        self.normalizar()

    def registrar_mal(self, cantidad):
        incremento = max(0, int(cantidad))
        self.mal += incremento
        self.normalizar()

    def estado(self):
        self.normalizar()
        return {
            "bien": self.bien,
            "mal": self.mal,
            "regla": self.regla,
            "prevalece": "bien"
        }


