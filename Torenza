# =========================================================
# IA CENTRAL DE ESTABILIDAD
# =========================================================
class IACentralEstable:
    def __init__(self, planeta, moral, leyes_roboticas, anclas, configuracion):
        self.nombre = "ATLAS-ETHOS"
        self.estado = "ACTIVA"
        self.modo = "SUPERVISION_ESTABLE_TOTAL"
        self.planeta = planeta
        self.moral = moral
        self.leyes_roboticas = leyes_roboticas
        self.anclas = anclas
        self.configuracion = configuracion
        self.decisiones_tomadas = 0

    def estabilizacion_automatica(self):
        accion = {
            "riesgo_humano": False,
            "desorden_critico": False,
            "autodestruccion": False
        }

        aprobada, motivo = self.leyes_roboticas.evaluar_accion(accion)
        if not aprobada:
            return {
                "resultado": "BLOQUEADO",
                "motivo": motivo
            }

        self.decisiones_tomadas += 1
        evento = self.planeta.estabilizar(self.anclas, self.moral)

        return {
            "resultado": "ESTABILIZACION_EJECUTADA",
            "motivo": motivo,
            "evento": evento,
            "estado_ia": self.estado_actual()
        }

    def ajuste_manual(self, ajuste):
        accion = {
            "riesgo_humano": False,
            "desorden_critico": False,
            "autodestruccion": False
        }

        aprobada, motivo = self.leyes_roboticas.evaluar_accion(accion)
        if not aprobada:
            return {
                "resultado": "BLOQUEADO",
                "motivo": motivo
            }

        self.decisiones_tomadas += 1
        evento = self.planeta.aplicar_ajuste_seguro(ajuste, self.anclas, self.moral)

        return {
            "resultado": "AJUSTE_MANUAL_EJECUTADO",
            "motivo": motivo,
            "evento": evento,
            "estado_ia": self.estado_actual()
        }

    def estado_actual(self):
        return {
            "nombre": self.nombre,
            "estado": self.estado,
            "modo": self.modo,
            "decisiones_tomadas": self.decisiones_tomadas,
            "autoridad_superior": [
                "Dios",
                "Jesús, su Hijo",
                "Espíritu Santo"
            ]
        }


