# ANCLAS CARDINALES DEL PLANETA
# =========================================================
class AnclasCardinales:
    def __init__(self):
        self.puntos_cardinales = {
            "norte": {
                "estado": "ESTABLE",
                "funcion": "Ancla polar superior"
            },
            "sur": {
                "estado": "ESTABLE",
                "funcion": "Ancla polar inferior"
            },
            "este": {
                "estado": "ESTABLE",
                "funcion": "Ancla de rotación y continuidad"
            },
            "oeste": {
                "estado": "ESTABLE",
                "funcion": "Ancla de equilibrio y compensación"
            }
        }
        self.integridad_global = 100

    def verificar(self):
        estados = [v["estado"] == "ESTABLE" for v in self.puntos_cardinales.values()]
        self.integridad_global = 100 if all(estados) else 75
        return {
            "integridad_global": self.integridad_global,
            "puntos_cardinales": self.puntos_cardinales
        }


# =========================================================
# PLANETA ESTABLE
# =========================================================
class PlanetaEstable:
    def __init__(self):
        self.nombre = "Zulia Prime - Sistema Planetario Alfa"
        self.tipo = "Planeta completo estabilizado"
        self.fundamento = "Dios"

        # Escala fija tipo Tierra
        self.radio_km = 6371
        self.diametro_km = 12742
        self.gravedad_m_s2 = 9.81
        self.superficie_total_km2 = 510100000

        self.tamano_fijo = True
        self.forma = "Esferoide estable"
        self.estado_fisico = "ESTABLE"
        self.colapso = False
        self.deformacion = False
        self.encogimiento = False
        self.derretimiento = False

        self.rotacion = "Sincronizada y estable"
        self.orbita = "Estable"
        self.clima = "Regulado"
        self.tectonica = "Compensada"
        self.habitabilidad = "Alta"
        self.nivel_estabilidad = 100

        self.infraestructura = {
            "energia": "Singularidad Magnética Estable",
            "movilidad": "Levitación Cuántica Supervisada",
            "red_datos": "Enlace Neuronal Ético",
            "residuos": "Reciclaje Molecular (0% Desecho)",
            "defensa": "Caja Dimensional Cerrada",
            "fundamento": "Dios"
        }

        self.historial = []

    def recalcular_estabilidad(self, anclas):
        revision_anclas = anclas.verificar()

        penalizacion = 0
        penalizacion += 40 if self.colapso else 0
        penalizacion += 20 if self.deformacion else 0
        penalizacion += 20 if self.encogimiento else 0
        penalizacion += 20 if self.derretimiento else 0

        self.nivel_estabilidad = max(0, revision_anclas["integridad_global"] - penalizacion)

        if self.nivel_estabilidad >= 95:
            self.estado_fisico = "ESTABLE"
        elif self.nivel_estabilidad >= 75:
            self.estado_fisico = "VIGILADO"
        else:
            self.estado_fisico = "INESTABLE"

    def blindar_tamano(self):
        self.tamano_fijo = True
        self.colapso = False
        self.deformacion = False
        self.encogimiento = False
        self.derretimiento = False
        self.forma = "Esferoide estable"

    def estabilizar(self, anclas, moral):
        self.blindar_tamano()
        self.rotacion = "Sincronizada y estable"
        self.orbita = "Estable"
        self.clima = "Regulado"
        self.tectonica = "Compensada"
        self.habitabilidad = "Alta"
        moral.fortalecer_bien(10)
        self.recalcular_estabilidad(anclas)

        evento = {
            "fecha": datetime.utcnow().isoformat() + "Z",
            "accion": "ESTABILIZACION_TOTAL",
            "resultado": "PLANETA_ESTABLE",
            "nivel_estabilidad": self.nivel_estabilidad
        }
        self.historial.append(evento)
        return evento

    def aplicar_ajuste_seguro(self, nombre_ajuste, anclas, moral):
        ajustes_validos = {
            "reforzar_campo_magnetico": "Campo magnético reforzado",
            "alinear_ejes": "Ejes alineados",
            "regular_clima": "Clima regulado",
            "reforzar_anclas_cardinales": "Anclas cardinales reforzadas",
            "armonizar_infraestructura": "Infraestructura armonizada"
        }

        descripcion = ajustes_validos.get(nombre_ajuste, "Ajuste general de estabilidad")
        moral.fortalecer_bien(5)
        self.blindar_tamano()

        if nombre_ajuste == "reforzar_anclas_cardinales":
            for punto in anclas.puntos_cardinales:
                anclas.puntos_cardinales[punto]["estado"] = "ESTABLE"

        self.recalcular_estabilidad(anclas)

        evento = {
            "fecha": datetime.utcnow().isoformat() + "Z",
            "accion": nombre_ajuste,
            "descripcion": descripcion,
            "resultado": "AJUSTE_APLICADO",
            "nivel_estabilidad": self.nivel_estabilidad
        }
        self.historial.append(evento)
        return evento

    def estado(self, anclas):
        self.recalcular_estabilidad(anclas)
        return {
            "nombre": self.nombre,
            "tipo": self.tipo,
            "fundamento": self.fundamento,
            "escala": {
                "radio_km": self.radio_km,
                "diametro_km": self.diametro_km,
                "gravedad_m_s2": self.gravedad_m_s2,
                "superficie_total_km2": self.superficie_total_km2,
                "referencia": "Similar al planeta Tierra"
            },
            "integridad_fisica": {
                "tamano_fijo": self.tamano_fijo,
                "forma": self.forma,
                "estado_fisico": self.estado_fisico,
                "colapso": self.colapso,
                "deformacion": self.deformacion,
                "encogimiento": self.encogimiento,
                "derretimiento": self.derretimiento
            },
            "equilibrio_planetario": {
                "rotacion": self.rotacion,
                "orbita": self.orbita,
                "clima": self.clima,
                "tectonica": self.tectonica,
                "habitabilidad": self.habitabilidad,
                "nivel_estabilidad": self.nivel_estabilidad
            },
            "infraestructura": self.infraestructura,
            "anclas_cardinales": anclas.verificar()
        }


