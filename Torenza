def orden_humana():
    data = request.get_json(silent=True) or {}

    accion = {
        "riesgo_humano": data.get("riesgo_humano", False),
        "desorden_critico": data.get("desorden_critico", False),
        "autodestruccion": data.get("autodestruccion", False)
    }

    aprobada, motivo = leyes_roboticas.evaluar_accion(accion)

    return jsonify({
        "orden": data.get("orden", "sin_orden"),
        "aprobada": aprobada,
        "motivo": motivo
    })


